[
  {
    "name": "decode_envelope_valid_echo",
    "target": "decode_envelope",
    "expect_ok": true,
    "envelope": {
      "version": 1,
      "id": "case-echo-1",
      "sender": "peer-1",
      "payload": {
        "method": "Echo",
        "data": "hello"
      }
    }
  },
  {
    "name": "decode_envelope_rejects_empty_id",
    "target": "decode_envelope",
    "expect_ok": false,
    "error_contains": "envelope id must not be empty",
    "envelope": {
      "version": 1,
      "id": "",
      "sender": "peer-1",
      "payload": {
        "method": "Echo",
        "data": "hello"
      }
    }
  },
  {
    "name": "parse_session_valid_single_hash",
    "target": "parse_session",
    "expect_ok": true,
    "envelope": {
      "version": 1,
      "id": "case-sign-1",
      "sender": "peer-sign",
      "payload": {
        "method": "Sign",
        "data": {
          "gid": "1111111111111111111111111111111111111111111111111111111111111111",
          "sid": "2222222222222222222222222222222222222222222222222222222222222222",
          "members": [1, 2],
          "hashes": ["aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"],
          "content": null,
          "kind": "message",
          "stamp": 1,
          "nonces": null
        }
      }
    }
  },
  {
    "name": "parse_session_wrong_payload_kind",
    "target": "parse_session",
    "expect_ok": false,
    "error_contains": "expected sign payload",
    "envelope": {
      "version": 1,
      "id": "case-sign-wrong",
      "sender": "peer-sign",
      "payload": {
        "method": "Echo",
        "data": "wrong-kind"
      }
    }
  },
  {
    "name": "parse_onboard_request_valid",
    "target": "parse_onboard_request",
    "expect_ok": true,
    "envelope": {
      "version": 1,
      "id": "case-onboard-req-1",
      "sender": "peer-onboard",
      "payload": {
        "method": "OnboardRequest",
        "data": {
          "share_pk": "020202020202020202020202020202020202020202020202020202020202020202",
          "idx": 2
        }
      }
    }
  },
  {
    "name": "parse_onboard_request_invalid_share_pk",
    "target": "parse_onboard_request",
    "expect_ok": false,
    "error_contains": "invalid byte length",
    "envelope": {
      "version": 1,
      "id": "case-onboard-req-bad",
      "sender": "peer-onboard",
      "payload": {
        "method": "OnboardRequest",
        "data": {
          "share_pk": "abcd",
          "idx": 2
        }
      }
    }
  },
  {
    "name": "parse_onboard_response_valid",
    "target": "parse_onboard_response",
    "expect_ok": true,
    "envelope": {
      "version": 1,
      "id": "case-onboard-res-1",
      "sender": "peer-onboard",
      "payload": {
        "method": "OnboardResponse",
        "data": {
          "group": {
            "group_pk": "030303030303030303030303030303030303030303030303030303030303030303",
            "threshold": 2,
            "members": [
              {
                "idx": 1,
                "pubkey": "020202020202020202020202020202020202020202020202020202020202020202"
              }
            ]
          },
          "nonces": []
        }
      }
    }
  },
  {
    "name": "parse_onboard_response_rejects_empty_members",
    "target": "parse_onboard_response",
    "expect_ok": false,
    "error_contains": "group members must not be empty",
    "envelope": {
      "version": 1,
      "id": "case-onboard-res-bad",
      "sender": "peer-onboard",
      "payload": {
        "method": "OnboardResponse",
        "data": {
          "group": {
            "group_pk": "030303030303030303030303030303030303030303030303030303030303030303",
            "threshold": 2,
            "members": []
          },
          "nonces": []
        }
      }
    }
  }
]
